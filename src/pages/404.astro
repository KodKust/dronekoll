---
/** 404 — engelsk (statisk hosting kan inte språkförhandla), pekar mot katalogen. */
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { hubCluster } from '../lib/model';

const skyImg = existsSync(join(process.cwd(), 'public', 'img', '404-drone.webp'));
---

<Base
  title="Page not found — DroneKoll"
  description="The page does not exist. Find drone rules for 55 countries."
  lang="en"
  noindex={true}
>
  <Header lang="en" cluster={hubCluster()} />
  <main id="main-content" class={`band band--canvas nf ${skyImg ? 'nf--img' : ''}`}>
    <div class="shell nf__grid">
      <div class="content nf__text">
        <p class="overline">404</p>
        <h1>This airspace is empty</h1>
        <p class="lede">The page you were looking for does not exist.</p>
        <p><a href="/en/">Browse drone rules for all countries →</a></p>
      </div>
      {skyImg && (
        <img class="nf__sky" src="/img/404-drone.webp" alt="" width="900" height="1124" loading="eager" decoding="async" />
      )}
    </div>
  </main>
  <Footer lang="en" />
</Base>

<style>
  .nf { min-height: 46vh; }
  .nf .content { display: grid; gap: var(--space-4); }
  .nf--img .nf__grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-7);
    align-items: center;
  }
  .nf__sky {
    width: 100%;
    max-width: 320px;
    height: auto;
    border-radius: var(--r-xl);
    justify-self: end;
  }
  @media (max-width: 700px) {
    .nf--img .nf__grid { grid-template-columns: 1fr; }
    .nf__sky { max-width: 220px; justify-self: center; }
  }
</style>
