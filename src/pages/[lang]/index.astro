---
/**
 * Språkhubb — /{lang}/ för alla 27 språk. Länder på hubbens språk först,
 * därefter alla länder på engelska (turist-/fallbacklänkar). /en/ blir
 * den fullständiga engelska katalogen (hålls medvetet skild från "/" som
 * är marknadshemmet).
 */
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CountryGrid from '../../components/CountryGrid.astro';
import AppCta from '../../components/AppCta.astro';
import {
  LANGUAGE_CODES,
  LANGUAGES,
  allCountryPages,
  countriesForLang,
  hubCluster,
  brandForLang,
} from '../../lib/model';
import { t } from '../../lib/i18n';
import { organizationLd, webSiteLd } from '../../lib/seo';

export function getStaticPaths() {
  return LANGUAGE_CODES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: string };
const localPages = countriesForLang(lang).sort((a, b) =>
  a.displayName.localeCompare(b.displayName, lang),
);
const enPages =
  lang === 'en'
    ? []
    : allCountryPages()
        .filter((p) => p.lang === 'en' && !localPages.some((lp) => lp.iso === p.iso))
        .sort((a, b) => a.displayName.localeCompare(b.displayName, 'en'));

const brand = brandForLang(lang);
const totalCountries = new Set(allCountryPages().map((p) => p.iso)).size;
const title = t('meta.title.hub', lang, { brand });
const description = t('meta.desc.hub', lang, { n: totalCountries });
const ldBlocks = [organizationLd(), webSiteLd(lang)];
---

<Base title={title} description={description} lang={lang} alternates={hubCluster()}>
  <Fragment slot="head">
    {ldBlocks.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
  </Fragment>

  <Header lang={lang} cluster={hubCluster()} />

  <main id="main-content">
  <section class="band band--paper">
    <div class="shell hub-hero">
      <h1>{t('hub.h1', lang)}</h1>
      <p class="lede prose">{t('hub.lede', lang)}</p>
    </div>
  </section>

  <section class="band band--canvas">
    <div class="shell hub-grids">
      {localPages.length > 0 && (
        <div>
          {lang !== 'en' && (
            /* v8 avsnitt 22.5: rendera det nativa språknamnet DIREKT (endonym ur
               LANGUAGES), aldrig en "In {language}"-meningsmall — den tolkades i
               flera språk som "i tidningen/boken/verket". Namnet är entydigt självt. */
            <p class="overline hub-label" lang={lang}>{LANGUAGES[lang]}</p>
          )}
          <CountryGrid lang={lang} pages={localPages} searchable={lang === 'en'} />
        </div>
      )}
      {enPages.length > 0 && (
        <div>
          <p class="overline hub-label">{t('hub.allInEnglish', lang)}</p>
          <CountryGrid lang={lang} pages={enPages} />
        </div>
      )}
    </div>
  </section>

  <section class="band band--paper">
    <div class="wide">
      <AppCta lang={lang} />
    </div>
  </section>
  </main>

  <Footer lang={lang} />
</Base>

<style>
  .hub-hero { display: grid; gap: var(--space-4); }
  .hub-grids { display: grid; gap: var(--space-7); }
  .hub-label { margin-bottom: var(--space-4); }
</style>
