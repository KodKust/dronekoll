---
/**
 * Regellistan — TYPOGRAFISK (inga kort, max 68ch). REN lista: reglerna står
 * fria utan per-rad-status/ikoner. Översynsdatum visas separat via
 * FreshnessBadge ("Rules checked {date}") — vi lovar aldrig "verifierad", men
 * säger när reglerna senast sågs över. Legal-registret/legalStatus är ett
 * INTERNT arbetsverktyg och surfas inte här (Kristoffers beslut 2026-07-24;
 * de gamla per-rad-taggarna undergrävde trovärdigheten).
 */
interface Props {
  rules: string[];
}
const { rules } = Astro.props;
---

<ul class="rules prose" data-stagger>
  {rules.map((text) => (
    <li class="rules__item">
      <span class="rules__marker" aria-hidden="true"></span>
      <span class="rules__text">{text}</span>
    </li>
  ))}
</ul>

<style>
  .rules { list-style: none; margin: 0; padding: 0; display: grid; gap: 16px; }
  .rules__item { display: flex; gap: var(--space-3); align-items: baseline; }
  .rules__marker {
    flex-shrink: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--ink-3);
    transform: translateY(-4px);
  }
  .rules__text { display: inline; }
</style>
