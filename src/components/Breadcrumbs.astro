---
/** Brödsmulor — caption-storlek, chevron-separatorer. BreadcrumbList-schema sätts i sidmallen. */
interface Props {
  items: Array<{ label: string; href?: string }>;
}
const { items } = Astro.props;
---

<nav class="bc" aria-label="Breadcrumb">
  <ol>
    {items.map((item, i) => (
      <li>
        {item.href ? <a href={item.href}>{item.label}</a> : <span aria-current="page">{item.label}</span>}
        {i < items.length - 1 && (
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
            <path d="m9 5 7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .bc ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: var(--text-caption);
    color: var(--ink-3);
  }
  .bc li { display: inline-flex; align-items: center; gap: var(--space-2); }
  .bc a { color: var(--ink-3); }
  .bc a:hover { color: var(--accent-ink); }
  .bc [aria-current] { color: var(--ink-2); font-weight: 500; }
</style>
