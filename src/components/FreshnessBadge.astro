---
/**
 * Freshness-badge — SSR (juridiskt granskningsdatum, "Regler kontrollerade
 * {datum}") kan uppgraderas klient-side av src/scripts/freshness.ts med en
 * SEPARAT feed-degraderingsnotering ur pappilappi status.json. Regel-datumet
 * skrivs ALDRIG över av teknisk pipeline-/feed-status (REPO-P0-03) — en
 * frisk feed bevisar inte att reglerna är aktuella. Fasta mått → CLS 0.
 */
import { t } from '../lib/i18n';

interface Props {
  lang: string;
  iso: string;
  lastVerified?: string;
  /** landet finns i status.json (19 övervakade) → klient-uppgradering aktiveras */
  monitored?: boolean;
}
const { lang, iso, lastVerified, monitored = false } = Astro.props;
---

<span
  class="pill freshness"
  data-freshness={monitored ? iso : undefined}
  data-lang={lang}
  data-msg-warn={t('freshness.liveWarn', lang)}
>
  <span class="pulse-dot" aria-hidden="true"></span>
  <span class="freshness__text tnum">
    {lastVerified
      ? t('freshness.updated', lang, { date: lastVerified })
      : t('freshness.checkedDaily', lang)}
  </span>
</span>

{/* No-op:ar utan [data-freshness] — villkorade hoisted scripts är opålitliga. */}
<script>
  import '../scripts/freshness';
</script>

<style>
  .freshness {
    background: var(--go-wash);
    color: var(--go-ink);
    font-weight: 500;
    font-size: var(--text-caption);
    min-height: 28px;
  }
  /* v8-revision: feed-degradering färgar INTE om hela badgen (skulle se ut
     som att reglerna är degraderade). Bara .freshness__feednote markeras. */
  .freshness__feednote { color: var(--warn-ink); font-weight: 600; }
</style>
