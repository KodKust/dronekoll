---
/**
 * Wordmark: ikonglyfen (miniatyr av den riktiga appikonen) + lokaliserat
 * varumärkesnamn. Glyfen är konstant; namnet växlar per sidans språk
 * (DrönarKollen/sv, DrohnenKoll/de, DroneKoll/en …).
 */
interface Props {
  brand: string;        // lokaliserat appName
  href?: string;        // länkmål (språkets hubb); utelämnas → ingen länk
  mono?: boolean;       // footer-variant: glyf i currentColor-kontur, utan chip
  size?: number;        // chip-storlek i px (default 24)
}
const { brand, href, mono = false, size = 24 } = Astro.props;
const gradId = `wm-bg-${Math.random().toString(36).slice(2, 8)}`;
const Tag = href ? 'a' : 'span';
---

<Tag class="wordmark" href={href}>
  {mono ? (
    <svg
      class="wordmark__glyph"
      width={size}
      height={size}
      viewBox="0 0 100 100"
      aria-hidden="true"
    >
      <g stroke="currentColor" stroke-width="6" fill="none" stroke-linecap="round">
        <circle cx="28" cy="28" r="10.5" />
        <circle cx="72" cy="28" r="10.5" />
        <circle cx="28" cy="72" r="10.5" />
        <circle cx="72" cy="72" r="10.5" />
        <path d="M50 50 L35.5 35.5 M50 50 L64.5 35.5 M50 50 L35.5 64.5 M50 50 L64.5 64.5" />
      </g>
      <circle cx="50" cy="50" r="5.4" fill="currentColor" />
    </svg>
  ) : (
    <svg
      class="wordmark__glyph"
      width={size}
      height={size}
      viewBox="0 0 100 100"
      aria-hidden="true"
    >
      <defs>
        <linearGradient id={gradId} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#3B81F5" />
          <stop offset="1" stop-color="#1E3A8B" />
        </linearGradient>
      </defs>
      <rect width="100" height="100" rx="29" fill={`url(#${gradId})`} />
      <g stroke="#fff" stroke-width="4.7" fill="none" stroke-linecap="round">
        <circle cx="28" cy="28" r="10.5" />
        <circle cx="72" cy="28" r="10.5" />
        <circle cx="28" cy="72" r="10.5" />
        <circle cx="72" cy="72" r="10.5" />
        <path d="M50 50 L35.5 35.5 M50 50 L64.5 35.5 M50 50 L35.5 64.5 M50 50 L64.5 64.5" />
      </g>
      <circle cx="50" cy="50" r="5.4" fill="#fff" />
    </svg>
  )}
  <span class="wordmark__name">{brand}</span>
</Tag>

<style>
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  a.wordmark:hover { text-decoration: none; }
  .wordmark__glyph { flex-shrink: 0; }
  .wordmark__name {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .band--navy .wordmark__name { color: #fff; }
</style>
