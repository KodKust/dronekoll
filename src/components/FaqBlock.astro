---
/**
 * FAQ — native <details>/<summary>, noll JS. Hairline-separatorer, inga kort.
 * FAQPage-JSON-LD byggs av EXAKT samma items i sidmallen (seo.faqLd).
 */
import type { FaqItem } from '../lib/seo';

interface Props {
  items: FaqItem[];
}
const { items } = Astro.props;
---

<div class="faq prose">
  {items.map((item) => (
    <details class="faq__item" id={item.id ? `faq-${item.id}` : undefined}>
      <summary class="faq__q">
        {item.q}
        <svg class="faq__plus" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 5v14M5 12h14" stroke-linecap="round" />
        </svg>
      </summary>
      <p class="faq__a">{item.a}</p>
    </details>
  ))}
</div>

{/* Djuplänk: #faq-visitor (från appens turistpanel via /go) ska visa SVARET,
    inte bara scrolla till en hopfälld fråga. Ovillkorligt inline-skript —
    villkorade hoistade script i Astro no-op:ar tyst utan målelement. */}
<script is:inline>
  (function () {
    function openTarget() {
      var h = location.hash;
      if (!h || h.indexOf('#faq-') !== 0) return;
      var el = document.getElementById(h.slice(1));
      if (el && el.tagName === 'DETAILS') el.open = true;
    }
    openTarget();
    window.addEventListener('hashchange', openTarget);
  })();
</script>

<style>
  .faq { display: grid; }
  .faq__item { border-bottom: 1px solid var(--hairline); }
  .faq__item:first-child { border-top: 1px solid var(--hairline); }
  .faq__q {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) 0;
    font-size: var(--text-h4);
    font-weight: 600;
    color: var(--ink);
    user-select: none;
  }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__plus {
    flex-shrink: 0;
    color: var(--ink-3);
    transition: transform var(--dur-fast) var(--ease-standard);
  }
  .faq__item[open] .faq__plus { transform: rotate(45deg); }
  .faq__a { padding: 0 0 var(--space-5); color: var(--ink-body); max-width: 62ch; }
</style>
