---
/**
 * App-CTA-panel — EN per sida, nära slutet. Kunskap först, sälj sist.
 * r20-panel med accent-wash-gradient (en av sajtens två sanktionerade
 * gradienter). Enhetsbild (lokaliserad crop) kommer i fas 8 — panelen
 * renderar utan bild tills dess (grid kollapsar snyggt).
 */
import { t } from '../lib/i18n';
import { brandForLang, loadFeatures } from '../lib/model';
import { APP_STORE_URL, PLAY_STORE_URL, loadRating } from '../lib/seo';
import StarRating from './StarRating.astro';

interface Props {
  lang: string;
  /**
   * Strängnyckel för brödtexten. Landssidor skickar tier-ärlig variant:
   * cta.body (zonkarta-löftet) ENDAST för overlay-länder, annars
   * cta.body.notam / cta.body.base. Default = generisk produktbeskrivning
   * för hem/hub/app-sidor (inte knuten till ett enskilt lands förmågor).
   */
  bodyKey?: string;
  /** sökväg till lokaliserad enhets-crop (fas 8); utelämnad → textpanel */
  deviceImage?: string;
  deviceAlt?: string;
}
const { lang, bodyKey = 'cta.body.generic', deviceImage, deviceAlt = '' } = Astro.props;
const brand = brandForLang(lang);
const featureLinks = loadFeatures().map((f) => ({
  href: `/${lang}/app/${f.slug}/`,
  name: t(`feat.${f.slug}.name`, lang),
}));
const rating = loadRating();
---

<section class="cta">
  <div class="cta__text">
    <p class="overline">{t('cta.overline', lang)}</p>
    <h2>{t('cta.title', lang)}</h2>
    <p class="cta__body">{t(bodyKey, lang, { brand })}</p>
    <p class="caption cta__features">
      {t('app.more', lang)}:
      {featureLinks.map((f, i) => (
        <Fragment>
          <a href={f.href}>{f.name}</a>{i < featureLinks.length - 1 && ' · '}
        </Fragment>
      ))}
    </p>
    <div class="cta__badges">
      <a class="cta__badge" href={APP_STORE_URL} rel="noopener">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M16.7 12.9c0-2.4 2-3.6 2.1-3.7-1.1-1.7-2.9-1.9-3.5-1.9-1.5-.2-2.9.9-3.7.9-.8 0-1.9-.9-3.2-.8-1.6 0-3.1 1-4 2.4-1.7 3-.4 7.4 1.2 9.8.8 1.2 1.8 2.5 3 2.4 1.2 0 1.7-.8 3.2-.8s1.9.8 3.2.8c1.3 0 2.2-1.2 3-2.4.9-1.4 1.3-2.7 1.3-2.8-.1 0-2.6-1-2.6-3.9zM14.4 5.2c.7-.8 1.1-1.9 1-3.1-1 0-2.2.7-2.9 1.5-.6.7-1.2 1.9-1 3 1.1.1 2.2-.6 2.9-1.4z"/>
        </svg>
        <span>App Store</span>
      </a>
      {PLAY_STORE_URL && (
        <a class="cta__badge" href={PLAY_STORE_URL} rel="noopener" aria-label={t('cta.play.alt', lang)}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M3.6 1.8 13.7 12 3.6 22.2c-.4-.2-.6-.6-.6-1.2V3c0-.6.2-1 .6-1.2zm11.3 11.4 2.6 2.6-11 6.3 8.4-8.9zm3.9-4.5 2.6 1.5c.8.5.8 1.7 0 2.2l-2.6 1.5-2.9-2.6 2.9-2.6zM6.5 2.5l11 6.3-2.6 2.6-8.4-8.9z"/>
          </svg>
          <span>Google Play</span>
        </a>
      )}
      {rating && <StarRating value={rating.value} source={rating.source} lang={lang} />}
    </div>
  </div>
  {deviceImage && (
    <div class="cta__device">
      <img src={deviceImage} alt={deviceAlt} loading="lazy" decoding="async" width="320" height="660" />
    </div>
  )}
</section>

<style>
  .cta {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-7);
    align-items: center;
    background: linear-gradient(135deg, var(--accent-wash), #fff 70%);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: var(--space-7);
    overflow: hidden;
  }
  .cta__text { display: grid; gap: var(--space-4); max-width: 46ch; }
  .cta__body { color: var(--ink-body); }
  .cta__features { color: var(--ink-2); }
  .cta__features a { color: var(--accent-ink); font-weight: 500; }
  .cta__badges { display: flex; gap: var(--space-3); flex-wrap: wrap; }
  .cta__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--ink);
    color: #fff;
    border-radius: 10px;
    padding: 10px 18px;
    font-size: var(--text-small);
    font-weight: 600;
    transition: transform var(--dur-lift) var(--ease-standard);
  }
  .cta__badge:hover { color: #fff; text-decoration: none; transform: translateY(-1px); }
  .cta__device img {
    transform: rotate(-3deg);
    border-radius: 28px;
    box-shadow: var(--shadow-3);
    height: auto;
  }
  @media (max-width: 768px) {
    .cta { grid-template-columns: 1fr; padding: var(--space-6); }
    .cta__device { justify-self: center; }
    .cta__device img { max-width: 240px; }
  }
</style>
