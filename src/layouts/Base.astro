---
/**
 * Bas-layout — äger <head>: titel, beskrivning, canonical, hreflang-kluster,
 * OG-taggar och favicons. SEO-berikning (JSON-LD m.m.) byggs i src/lib/seo.ts
 * och skickas in via props/slots (fas 5).
 */
import '@fontsource-variable/manrope';
import '@fontsource-variable/inter';
import '../styles/tokens.css';
import '../styles/global.css';
import LangBanner from '../components/LangBanner.astro';
import { GOATCOUNTER_CODE } from '../lib/seo';

export interface Alternate {
  hreflang: string; // t.ex. "nl", "en", "x-default"
  href: string;     // absolut URL
}

interface Props {
  title: string;
  description: string;
  lang: string;            // sidans språk (html lang)
  canonical?: string;      // absolut URL; default = aktuell sida
  alternates?: Alternate[];// hreflang-kluster inkl. självreferens
  ogImage?: string;        // absolut URL till OG-bild
  noindex?: boolean;
}

const {
  title,
  description,
  lang,
  canonical = new URL(Astro.url.pathname, Astro.site).href,
  alternates = [],
  ogImage,
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#3B81F5" />

    {/* js-flagga FÖRE first paint — stagger-döljningen är gated bakom html.js
        så no-JS-besökare (och crawlers utan JS) alltid ser allt innehåll. */}
    <script is:inline>document.documentElement.classList.add('js');</script>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta name="twitter:card" content="summary_large_image" />}

    <slot name="head" />

    {/* GoatCounter — cookiefri analys (gated: renderas bara när GOATCOUNTER_CODE satt).
        Beacon + iOS/Android-klick-events för pappilappi/status-baren. */}
    {GOATCOUNTER_CODE && (
      <Fragment>
        {/* Preconnect till beacon-värden — sparar DNS+TLS när count.js hämtas.
            Utan crossorigin: count.js laddas som vanligt script (ej CORS), så
            connectionen ska matcha den icke-CORS-hämtningen för att återanvändas. */}
        <link rel="preconnect" href="https://gc.zgo.at" />
        <script
          data-goatcounter={`https://${GOATCOUNTER_CODE}.goatcounter.com/count`}
          async
          src="//gc.zgo.at/count.js"
        ></script>
        <script is:inline>
          {/* Store-klick → events (path=ios-click/android-click), med GoatCounters
              inbyggda land-data per hit. Delegerad lyssnare täcker alla store-länkar. */}
          document.addEventListener('click', function (e) {
            var a = e.target.closest && e.target.closest('a[href]');
            if (!a || !window.goatcounter || !window.goatcounter.count) return;
            var h = a.href;
            if (h.indexOf('apps.apple.com') > -1)
              window.goatcounter.count({ path: 'ios-click', title: 'iOS store click', event: true });
            else if (h.indexOf('play.google.com') > -1)
              window.goatcounter.count({ path: 'android-click', title: 'Android store click', event: true });
          });
        </script>
      </Fragment>
    )}
  </head>
  <body>
    <slot />
    <LangBanner lang={lang} />
    <script>
      import '../scripts/motion';
    </script>
  </body>
</html>
