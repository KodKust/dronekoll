{
  "name": "dronekoll-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/fetch-data.mjs && node scripts/build-manifest.mjs && astro build && node scripts/verify-build.mjs",
    "build:offline": "node scripts/build-manifest.mjs && astro build && node scripts/verify-build.mjs",
    "preview": "astro preview",
    "fetch-data": "node scripts/fetch-data.mjs",
    "build-manifest": "node scripts/build-manifest.mjs",
    "verify": "node scripts/verify-build.mjs",
    "validate-snapshot": "node scripts/validate-snapshot.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:api": "node scripts/check-api-contract.mjs",
    "check": "npm run build:offline && node scripts/check-en-staleness.mjs && npm run check-matrix-staleness && npm run check:links && npm run check:api",
    "check-matrix-staleness": "node scripts/check-matrix-staleness.mjs"
  },
  "dependencies": {
    "astro": "^5.0.0",
    "leaflet": "^1.9.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.1.0",
    "@fontsource-variable/manrope": "^5.1.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@resvg/resvg-js": "^2.6.0",
    "@types/leaflet": "^1.9.0",
    "satori": "^0.12.0",
    "sharp": "^0.33.0"
  }
}
