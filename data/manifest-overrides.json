  "SE": {
    "_why": "LFV WFS (daim.lfv.se) saknar CORS + statisk spegel — fetch-se-zones.yml (dronarkartan) skapar se-zones.geojson. Tills den landat: layers tom → sidan degraderar graciöst.",
    "dropDerived": true,
    "attribution": "LFV",
    "layers": [
      { "id": "se-zones", "url": "https://pappilappi.com/airspace/web/se-zones.geojson", "typeProp": "_zoneType", "defaultOn": true, "label": "Restriktionsområden", "pendingFetcher": true }
    ]
  },

