{
  "_comment": "Människokuraterade kart-lager per land — slås ihop ÖVER det som build-manifest.mjs härleder ur countries.json. Nycklar per land: layers (ersätter helt när satt), attribution, dropDerived (true = ignorera countries.json-feeds). Verifieras/förfinas i fas 4-QA mot pappilappi/airspace/-inventariet.",

  "CH": {
    "_why": "Appens primär är geoadmin-API (ej CORS-vänlig för webben); pappilappi har 9 statiska ch-*-feeds som täcker webbfallet.",
    "dropDerived": true,
    "attribution": "BAZL/BAFU/VBS · geo.admin.ch",
    "layers": [
      { "id": "ch-uas", "url": "https://pappilappi.com/airspace/web/ch-uas-aktivitaetszonen.geojson", "typeProp": "_zoneType", "zoneKeyDefault": "UAS_AKT_CH", "defaultOn": true, "label": "UAS-zoner" },
      { "id": "ch-ctr", "url": "https://pappilappi.com/airspace/web/ch-ctr.geojson", "typeProp": "_zoneType", "zoneKeyDefault": "CTR_CH", "defaultOn": true, "label": "CTR" },
