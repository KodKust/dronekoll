      { "id": "ch-schiess", "url": "https://pappilappi.com/airspace/web/ch-schiessanzeigen.geojson", "typeProp": "_zoneType", "zoneKeyDefault": "SCHIESS_CH", "defaultOn": false, "label": "Schiessanzeigen" },
